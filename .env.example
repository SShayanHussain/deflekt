# .env.example — Deflekt
# Copy to .env and fill real values. .env is gitignored. Never commit secrets.

# --- App (Next.js) ---
NODE_ENV=development
APP_URL=http://localhost:3000
JWT_ACCESS_SECRET=change-me-short-lived
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_TTL=1209600       # seconds (14 days)

# --- Database ---
DATABASE_URL=postgresql://deflekt:deflekt@localhost:5432/deflekt
# pgvector extension must be enabled on this DB

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AI service (FastAPI) ---
AI_SERVICE_URL=http://localhost:8000
# LLM key for Gemini (via the google-genai SDK). Either name works; GEMINI_API_KEY wins.
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=                # optional fallback key slot
LLM_MODEL_CHEAP=gemini-2.5-flash   # generation + faithfulness model
CONFIDENCE_THRESHOLD=0.72     # tune against eval set

# --- Storage (S3) ---
# If AWS creds/bucket are absent, uploads fall back to a shared local volume.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_S3_BUCKET=deflekt-docs-dev

# --- Email (verify / reset) ---
EMAIL_FROM=noreply@deflekt.app
EMAIL_PROVIDER_KEY=your-email-provider-key

# --- Billing (stub / Stripe test mode) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
